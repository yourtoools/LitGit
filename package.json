{
  "name": "litgit",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "@mantine/hooks": "^8.3.18",
      "@phosphor-icons/react": "^2.1.10",
      "@types/node": "^25.5.0",
      "@types/react": "19.2.14",
      "@types/react-dom": "19.2.3",
      "date-fns": "4.1.0",
      "dotenv": "^17.3.1",
      "next-themes": "^0.4.6",
      "react": "19.2.4",
      "react-dom": "19.2.4",
      "sonner": "^2.0.7",
      "tailwindcss": "^4.2.2",
      "typescript": "^6.0.2",
      "zod": "^4.3.6"
    }
  },
  "type": "module",
  "scripts": {
    "build": "turbo build",
    "build:desktop": "turbo run build -F desktop",
    "build:desktop-web": "turbo run build:desktop-web -F desktop",
    "check": "ultracite check",
    "check-types": "bun x turbo run check-types --dangerously-disable-package-manager-check",
    "dev": "turbo dev",
    "dev:desktop:cdp": "turbo run dev:cdp -F desktop",
    "dev:desktop": "turbo run dev -F desktop",
    "dev:desktop-web": "turbo run dev:desktop-web -F desktop",
    "fix": "ultracite fix",
    "gen:gitignore-templates": "turbo run gen:gitignore-templates -F desktop",
    "bump-deps": "bun run scripts/bump.mjs",
    "bump-deps:audit": "bun run scripts/bump.mjs --audit",
    "bump-deps:ci": "bun run scripts/bump.mjs --yes",
    "bump-deps:dry": "bun run scripts/bump.mjs --dry-run",
    "bump-deps:safe": "bun run scripts/bump.mjs --skip-major",
    "bump-deps:stable": "bun run scripts/bump.mjs --only-type stable",
    "clean": "bun run scripts/cleanup.mjs",
    "clean:all": "bun run scripts/cleanup.mjs --all"
  },
  "dependencies": {
    "@litgit/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.9",
    "@inquirer/prompts": "^8.3.2",
    "@litgit/config": "workspace:*",
    "lefthook": "2.1.4",
    "turbo": "^2.8.20",
    "typescript": "catalog:",
    "ultracite": "7.3.2"
  },
  "packageManager": "bun@1.3.10"
}
