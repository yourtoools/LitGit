{
  "name": "LitGit",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.2.2",
      "zod": "^4.1.13",
      "typescript": "^5"
    }
  },
  "type": "module",
  "scripts": {
    "build": "turbo build",
    "build:desktop": "turbo run build -F desktop",
    "build:desktop-web": "turbo run build:desktop-web -F desktop",
    "check": "ultracite check",
    "check-types": "turbo check-types",
    "dev": "turbo dev",
    "dev:desktop": "turbo run dev -F desktop",
    "dev:desktop-web": "turbo run dev:desktop-web -F desktop",
    "dev:native": "turbo -F native dev",
    "fix": "ultracite fix"
  },
  "dependencies": {
    "@LitGit/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@LitGit/config": "workspace:*",
    "@biomejs/biome": "2.4.5",
    "lefthook": "latest",
    "turbo": "^2.8.12",
    "typescript": "catalog:",
    "ultracite": "7.2.5"
  },
  "packageManager": "bun@1.3.10"
}
