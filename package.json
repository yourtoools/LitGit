{
  "name": "litgit",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "@types/node": "^25.3.3",
      "dotenv": "^17.3.1",
      "zod": "^4.3.6",
      "typescript": "^5.9.3",
      "react": "19.2.4",
      "react-dom": "19.2.4",
      "tailwindcss": "^4.2.1",
      "@types/react": "19.2.14",
      "@types/react-dom": "19.2.3",
      "@phosphor-icons/react": "^2.1.10",
      "next-themes": "^0.4.6",
      "sonner": "^2.0.7"
    }
  },
  "type": "module",
  "scripts": {
    "build": "turbo build",
    "build:desktop": "turbo run build -F desktop",
    "build:desktop-web": "turbo run build:desktop-web -F desktop",
    "check": "ultracite check",
    "check-types": "turbo check-types",
    "dev": "turbo dev",
    "dev:desktop": "turbo run dev -F desktop",
    "dev:desktop-web": "turbo run dev:desktop-web -F desktop",
    "fix": "ultracite fix",
    "gen:gitignore-templates": "turbo run gen:gitignore-templates -F desktop"
  },
  "dependencies": {
    "@litgit/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.5",
    "@litgit/config": "workspace:*",
    "lefthook": "2.1.2",
    "turbo": "^2.8.12",
    "typescript": "catalog:",
    "ultracite": "7.2.4"
  },
  "packageManager": "bun@1.3.10"
}
