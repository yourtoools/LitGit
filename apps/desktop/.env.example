# -----------------------------------------------
# External Links
# -----------------------------------------------
# Repository URL for "Source code".
VITE_SOURCE_CODE_URL="https://github.com/yourtoools/Litgit"
# Issue tracker URL for "Report a bug".
VITE_BUG_REPORT_URL="https://github.com/yourtoools/Litgit/issues"
# Release notes URL for footer version link.
VITE_RELEASE_NOTES_URL="https://github.com/yourtoools/Litgit/releases"

# -----------------------------------------------
# OAuth Configuration
# -----------------------------------------------
# LitGit uses loopback redirect URIs per RFC 8252. Register these in your OAuth app:
#
#   GitHub:     http://127.0.0.1/callback      (accepts any port)
#   GitLab:     http://127.0.0.1:8765/callback (exact match required)
#   Bitbucket:  http://127.0.0.1/callback      (accepts any port)
#
# Fallback: litgit://oauth/callback (registered in tauri.conf.json)
# GitHub: https://github.com/settings/applications/new
# Callback: http://127.0.0.1/callback
GITHUB_CLIENT_ID="your_github_client_id_here"
GITHUB_CLIENT_SECRET="your_github_client_secret_here"
# GitLab: https://gitlab.com/-/profile/applications
# Redirect URI: http://127.0.0.1:8765/callback
# Scopes: api, read_repository, write_repository, read_user
GITLAB_CLIENT_ID="your_gitlab_client_id_here"
GITLAB_CLIENT_SECRET="your_gitlab_client_secret_here"
# Bitbucket: https://bitbucket.org/[workspace]/workspace/settings/oauth-consumers/new
# Callback: http://127.0.0.1/callback
# Permissions: Repositories (Read, Write), Account (Read)
BITBUCKET_CLIENT_ID="your_bitbucket_client_id_here"
BITBUCKET_CLIENT_SECRET="your_bitbucket_client_secret_here"
