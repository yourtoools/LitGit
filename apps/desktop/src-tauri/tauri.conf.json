{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "LitGit Desktop",
  "version": "0.1.0",
  "identifier": "com.yourtoools.litgit",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:3001",
    "beforeDevCommand": "cd .. && bun run dev:desktop-web",
    "beforeBuildCommand": "cd .. && bun run build:desktop-web"
  },
  "app": {
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "category": "DeveloperTool",
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["litgit"]
      }
    }
  }
}
