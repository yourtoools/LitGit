{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "LitGit Desktop",
  "version": "0.1.0",
  "identifier": "com.tauri.dev",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:3001",
    "beforeDevCommand": "cd .. && bun run dev:desktop-web",
    "beforeBuildCommand": "cd .. && bun run build:desktop-web"
  },
  "app": {
    "windows": [
      {
        "title": "LitGit Desktop",
        "width": 1100,
        "height": 720,
        "center": true,
        "decorations": false,
        "shadow": true,
        "resizable": true,
        "fullscreen": false,
        "maximized": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
