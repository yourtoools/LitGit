{
  "$schema": "https://turbo.build/schema.json",
  "ui": "stream",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": ["dist/**"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "dev:cdp": {
      "cache": false,
      "persistent": true
    },
    "dev:desktop-web": {
      "cache": false,
      "persistent": true
    },
    "build:desktop-web": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": ["dist/**"]
    },
    "gen:gitignore-templates": {
      "outputs": ["src/lib/generated/gitignore-templates.ts"]
    },
    "generate:lucide-icons": {
      "outputs": ["src/icons/LucideIcons.ts"]
    },
    "bump-skills": {
      "cache": false
    },
    "bump-skills:dry": {
      "cache": false
    }
  }
}
